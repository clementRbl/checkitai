# Identifiant utilisateur pour les conteneurs Airflow (sous Linux : votre UID).
# Obtenir la valeur avec : id -u
AIRFLOW_UID=50000

# Cle API NewsData.io utilisee par la tache d'extraction.
NEWS_DATA_API_KEY=

# Mot de passe de la base de donnees metier (checkit-postgres).
# A remplacer par un mot de passe fort en dehors d'un usage local de demo.
CHECKIT_DB_PASSWORD=checkit

# Cle Fernet utilisee par Airflow pour chiffrer connexions et variables sensibles.
# Generer une cle une seule fois (sans dependance supplementaire) avec :
#   python -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
AIRFLOW_FERNET_KEY=
